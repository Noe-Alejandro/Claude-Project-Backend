{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ClaudeProjectBackend;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Secret": "REPLACE-VIA-USER-SECRETS-OR-ENV-VAR",
    "Issuer": "ClaudeProjectBackend",
    "Audience": "ClaudeProjectWeb",
    "ExpiryMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:5173"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*"
}
